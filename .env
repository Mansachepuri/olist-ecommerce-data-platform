# -------------------------
# Postgres (Airflow metadata now, warehouse later)
# -------------------------
POSTGRES_USER=manasa
POSTGRES_PASSWORD=manasa123
POSTGRES_DB=etl_warehouse
POSTGRES_PORT=5432

# -------------------------
# Airflow admin user (for first login)
# -------------------------
AIRFLOW_ADMIN_USER=manasa
AIRFLOW_ADMIN_PASSWORD=manasa123
AIRFLOW_ADMIN_EMAIL=manasagoudchepuri@gmail.com
AIRFLOW_ADMIN_FIRSTNAME=manasa
AIRFLOW_ADMIN_LASTNAME=chepuri

# -------------------------
# Airflow core config (minimal + production-ish)
# -------------------------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True

# Airflow uses Fernet for connection secrets (set a stable value)
# Generate your own later, but this is fine for local dev
AIRFLOW__CORE__FERNET_KEY=5zCv4_iR4gp8Ay_VBcz-w14YQ2zJBcOZjN2Sinv1S3E=

# -------------------------
# Paths inside containers
# -------------------------
AIRFLOW_HOME=/opt/airflow
DATA_DIR=/opt/data

# -------------------------
# Host port mappings
# -------------------------
AIRFLOW_PORT=8080
METABASE_PORT=3000

# -------------------------
# Linux-only: helps file permissions on bind mounts
# If you're on Mac/Windows, this is harmless
# -------------------------
AIRFLOW_UID=50000
AIRFLOW__WEBSERVER__SESSION_BACKEND=securecookie
